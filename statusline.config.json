{
  "features": {
    "usageLimits": true,
    "spendTracking": false
  },
  "oneLine": false,
  "showSonnetModel": false,
  "pathDisplayMode": "truncated",
  "git": {
    "enabled": true,
    "showBranch": true,
    "showDirtyIndicator": true,
    "showChanges": false,
    "showStaged": true,
    "showUnstaged": true,
    "showAheadBehind": true
  },
  "separator": "•",
  "session": {
    "infoSeparator": null,
    "cost": { "enabled": true, "format": "decimal1" },
    "duration": { "enabled": true },
    "tokens": { "enabled": true, "showMax": true, "showDecimals": false },
    "percentage": {
      "enabled": true,
      "showValue": true,
      "progressBar": {
        "enabled": true,
        "length": 10,
        "style": "braille",
        "color": "progressive",
        "background": "none"
      }
    },
    "costPerHour": { "enabled": true, "format": "decimal1" },
    "apiRatio": { "enabled": false },
    "outputTokens": { "enabled": true },
    "alert200k": { "enabled": true }
  },
  "context": {
    "usePayloadContextWindow": true,
    "maxContextTokens": 1000000,
    "autocompactBufferTokens": 45000,
    "useUsableContextOnly": true,
    "overheadTokens": 0
  },
  "limits": {
    "enabled": true,
    "showTimeLeft": true,
    "showPacingDelta": true,
    "cost": { "enabled": true, "format": "decimal1" },
    "percentage": {
      "enabled": true,
      "showValue": true,
      "progressBar": {
        "enabled": true,
        "length": 10,
        "style": "braille",
        "color": "progressive",
        "background": "none"
      }
    }
  },
  "weeklyUsage": {
    "enabled": "90%",
    "showTimeLeft": true,
    "showPacingDelta": false,
    "cost": { "enabled": false, "format": "decimal1" },
    "percentage": {
      "enabled": true,
      "showValue": true,
      "progressBar": {
        "enabled": true,
        "length": 10,
        "style": "braille",
        "color": "progressive",
        "background": "none"
      }
    }
  },
  "dailySpend": {
    "cost": { "enabled": false, "format": "decimal1" }
  }
}
